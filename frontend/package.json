    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^24.1.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.5",
    "vitest": "^1.6.0"
  }
